# Server port
PORT=3000

# Secret used to sign and verify JWT tokens — use a long random string in production
JWT_SECRET=change-me-in-production

# Allowed origin for CORS (your frontend URL)
CLIENT_ORIGIN=http://localhost:5173

# Redis connection string
# Local (Docker Compose):  redis://redis:6379
# AWS ElastiCache:         rediss://<endpoint>:6379
REDIS_URL=redis://redis:6379

# MongoDB / DocumentDB connection string
# Local (Docker Compose):  mongodb://mongo:27017/pitch
# AWS DocumentDB:          mongodb://<user>:<pass>@<cluster-endpoint>:27017/pitch?tls=true&tlsCAFile=rds-ca.pem
MONGO_URI=mongodb://mongo:27017/pitch
