{
  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "rootDir": "src",
    "outDir": "dist",

    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true,

    "types":["node","jest"],
  },
  "include": ["src/**/*.ts", "src/types/**/*.d.ts", "src/types/socket", "src/tests/**/**/*.ts", "src/tests/**/*.ts"],
}
